# Ollama configuration (local LLM). The defaults work out of the box if Ollama
# runs on the same machine with the default port. Copy this file to ".env" to override.

# Base URL of the Ollama server.
OLLAMA_HOST="http://localhost:11434"

# Model used for all generations. Pull it first with: ollama pull qwen2.5:7b
OLLAMA_MODEL="qwen2.5:7b"
